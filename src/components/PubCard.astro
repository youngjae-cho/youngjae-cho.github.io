---
import type { Pub } from '../data/publications';
interface Props { pub: Pub; }
const { pub } = Astro.props;
---
<article class={pub.featured ? 'card feature' : 'card'}>
  {pub.featured && (
    <svg class="feature-contour" viewBox="0 0 200 200" fill="none" stroke="var(--accent)" stroke-width="1" aria-hidden="true">
      <ellipse cx="100" cy="100" rx="20" ry="16" /><ellipse cx="100" cy="100" rx="42" ry="34" />
      <ellipse cx="100" cy="100" rx="66" ry="55" /><ellipse cx="100" cy="100" rx="92" ry="78" />
      <circle cx="100" cy="100" r="3" fill="var(--accent)" stroke="none" />
    </svg>
  )}
  <div class="card-top">
    <span class={pub.venueAlt ? 'badge alt' : 'badge'}>{pub.venue}</span>
    {pub.role && (
      <span class={pub.roleFirst ? 'role-tag first' : 'role-tag'}>{pub.roleFirst ? '★ ' : ''}{pub.role}</span>
    )}
  </div>
  <h3>{pub.acronym && <span class="acro">{pub.acronym}</span>}{pub.acronym ? ' — ' : ''}{pub.title}</h3>
  <p set:html={pub.summary}></p>
  {pub.chips && (
    <div class="chips">{pub.chips.map((c) => <span class="chip" set:html={c}></span>)}</div>
  )}
  {pub.url && (
    <a class="more" href={pub.url}>Read the paper <span class="arr">→</span></a>
  )}
</article>
